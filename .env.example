DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your_mapbox_token_here"

# TURN relay for cross-network WebRTC calls. Without these, calls only work
# between peers on the same/friendly network (STUN-only fallback). Get free
# creds at https://www.metered.ca (free tier ~50GB/mo).
NEXT_PUBLIC_TURN_URLS="turn:host:80,turn:host:80?transport=tcp,turn:host:443,turns:host:443?transport=tcp"
NEXT_PUBLIC_TURN_USERNAME="your_turn_username"
NEXT_PUBLIC_TURN_CREDENTIAL="your_turn_credential"
